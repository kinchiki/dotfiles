{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(codex review:*)",
      "Bash(codex exec review:*)",
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(touch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh release list:*)",
      "Bash(git add:*)",
      "Bash(git apply:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(git switch:*)",
      "Bash(git worktree:*)",
      "Bash(terraform fmt:*)",
      "Bash(tflint:*)",
      "Bash(trivy:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__notion__search",
      "mcp__notion__fetch",
      "mcp__notion__notion-fetch",
      "mcp__linear__get_issue",
      "mcp__Sentry__get_issue_details",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__get-library-docs",
      "mcp__github__list_pull_requests",
      "mcp__github__get_me",
      "mcp__github__search_pull_requests",
      "mcp__github__search_repositories",
      "mcp__github__pull_request_read"
    ],
    "deny": [
      "Bash(env:*)",
      "Bash(mongod:*)",
      "Bash(mysql:*)",
      "Bash(nc:*)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(op:*)",
      "Bash(psql:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "mcp__supabase__execute_sql",
      "NotebookEdit",
      "Read(~/src/**/.ai-local/**/archive/**)",
      "Read(~/src/**/.claude/**/archive/**)",
      "Read(~/src/**/.codex/**/archive/**)",
      "Read(id_ecdsa)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(.envrc)",
      "Edit(.envrc)",
      "Read(.env)",
      "Edit(.env)",
      "Read(.env.local)",
      "Edit(.env.local)",
      "Read(.env.*.local)",
      "Edit(.env.*.local)",
      "Read(.env.production)",
      "Edit(.env.production)",
      "Read(*.private.env)",
      "Edit(*.private.env)",
      "Read(*.key)",
      "Edit(*.key)",
      "Read(*.pem)",
      "Edit(*.pem)",
      "Read(*.p12)",
      "Edit(*.p12)",
      "Read(*.pfx)",
      "Edit(*.pfx)",
      "Read(*.jks)",
      "Edit(*.jks)",
      "Read(*.keystore)",
      "Edit(*.keystore)",
      "Read(client_secret*.json)",
      "Edit(client_secret*.json)",
      "Read(*service-account*.json)",
      "Edit(*service-account*.json)",
      "Read(credentials.json)",
      "Edit(credentials.json)",
      "Read(kubeconfig)",
      "Edit(kubeconfig)",
      "Read(*.tfstate)",
      "Edit(*.tfstate)",
      "Read(*.tfstate.*)",
      "Edit(*.tfstate.*)",
      "Read(*.tfvars)",
      "Edit(*.tfvars)",
      "Read(credentials.yml.enc)",
      "Edit(credentials.yml.enc)",
      "Read(**/credentials/*.yml.enc)",
      "Edit(**/credentials/*.yml.enc)",
      "Read(.npmrc)",
      "Edit(.npmrc)",
      "Read(.pypirc)",
      "Edit(.pypirc)",
      "Read(.netrc)",
      "Edit(.netrc)",
      "Read(**/dumps/**)",
      "Edit(**/dumps/**)",
      "Read(~/.zshrc.local)",
      "Edit(~/.zshrc.local)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.netrc)",
      "Edit(~/.netrc)",
      "Read(~/.git-credentials)",
      "Edit(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Edit(~/.docker/config.json)"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git revert:*)",
      "Bash(git tag:*)",
      "Bash(git publish:*)",
      "Bash(gh pr create:*)",
      "mcp__linear__list_comments",
      "mcp__linear__create_comment",
      "mcp__linear__list_cycles",
      "mcp__linear__get_document",
      "mcp__linear__list_documents",
      "mcp__linear__list_issues",
      "mcp__linear__create_issue",
      "mcp__linear__update_issue",
      "mcp__linear__list_issue_statuses"
    ],
    "additionalDirectories": [
      "~/src/"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "api.openai.com",
        "*.api.openai.com",
        "auth.openai.com",
        "chatgpt.com",
        "*.chatgpt.com",
        "*.openai.com",
        "github.com",
        "api.github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "copilot-proxy.githubusercontent.com",
        "origin-tracker.githubusercontent.com",
        "*.githubcopilot.com",
        "*.individual.githubcopilot.com",
        "*.business.githubcopilot.com",
        "*.enterprise.githubcopilot.com",
        "collector.github.com",
        "copilot-telemetry.githubusercontent.com",
        "default.exp-tas.com",
        "npm.flatt.tech",
        "npmjs.org",
        "*.npmjs.org",
        "registry.npmjs.org",
        "mise.jdx.dev",
        "mcp.figma.com",
        "mcp.linear.app",
        "mcp.notion.com",
        "mcp.sentry.dev"
      ],
      "allowUnixSockets": [
        "~/.colima/default/docker.sock",
        "~/.colima/docker.sock",
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true,
      "allowMachLookup": [
        "com.apple.trustd.agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/dev/ttys",
        "/dev/ptmx",
        "/tmp",
        "~/src/",
        "~/.codex/",
        "~/.local/share/mise/",
        "~/.local/state/mise/",
        "~/.config/mise/",
        "~/Library/Caches/mise/",
        "~/.npm/",
        "~/.colima/",
        "~/.docker/",
        "~/.config/gh/",
        "~/.local/share/aquaproj-aqua/",
        "~/.cache/trivy/"
      ],
      "denyWrite": [
        "/etc"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        "/dev/ttys",
        "/dev/ptmx",
        "~/src/",
        "~/.zshrc",
        "~/.gitconfig",
        "~/.codex/",
        "~/.copilot/",
        "~/.local/share/mise/",
        "~/.local/state/mise/",
        "~/.config/mise/",
        "~/Library/Caches/mise/",
        "~/.docker/",
        "~/.colima/",
        "~/.lima/",
        "~/.config/gh/",
        "~/.local/share/aquaproj-aqua/"
      ]
    },
    "credentials": {
      "files": [
        {
          "path": "~/.zshrc.local",
          "mode": "deny"
        },
        {
          "path": "~/.ssh",
          "mode": "deny"
        },
        {
          "path": "~/.aws",
          "mode": "deny"
        },
        {
          "path": "~/.netrc",
          "mode": "deny"
        },
        {
          "path": "~/.git-credentials",
          "mode": "deny"
        },
        {
          "path": "~/.docker/config.json",
          "mode": "deny"
        }
      ],
      "envVars": [
        {
          "name": "GH_TOKEN",
          "mode": "deny"
        },
        {
          "name": "GITHUB_TOKEN",
          "mode": "deny"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "mode": "deny"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "mode": "deny"
        },
        {
          "name": "AWS_SESSION_TOKEN",
          "mode": "deny"
        }
      ]
    },
    "excludedCommands": [
      "codex exec review *",
      "codex review *",
      "~/src/dotfiles/agent-resources/skills/implement-plan/scripts/review-codex.sh*",
      "$(git rev-parse --show-toplevel)/agent-resources/skills/implement-plan/scripts/review-codex.sh",
      "tflint *"
    ]
  },
  "effortLevel": "high",
  "plansDirectory": ".claude/plans",
  "theme": "dark",
  "preferredNotifChannel": "terminal_bell",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
