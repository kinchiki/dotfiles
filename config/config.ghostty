# Ghostty インストール後に以下を実行する
# ln -s ~/src/dotfiles/config/config.ghostty ~/Library/Application\ Support/com.mitchellh.ghostty/config.ghostty

font-family = "Bizin Gothic NF"
font-family-bold = "Bizin Gothic NF Bold"
font-size = 22

cursor-style = bar
# 点滅しなくなることがあったので明示する
cursor-style-blink = true

# Option キーを Alt として扱う（tmux の M-* キーバインドを使うため）
macos-option-as-alt = true

# surface（ウィンドウ・タブ・ペインなど）を閉じるときに確認ダイアログを出す
confirm-close-surface = always
