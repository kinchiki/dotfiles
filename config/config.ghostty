# Ghostty インストール後に以下を実行する
# ln -s ~/src/dotfiles/config/config.ghostty ~/Library/Application\ Support/com.mitchellh.ghostty/config.ghostty

font-family = "Bizin Gothic NF Regular"
font-family-bold = "Bizin Gothic NF Bold"
font-size = 20

cursor-style = bar
# 点滅しなくなることがあったので明示する
cursor-style-blink = true
