# Claude の settings.json に合わせている
# Claude "ask" maps to Codex "prompt"; Claude "deny" maps to "forbidden".
# These rules apply when Codex requests to run a command outside the sandbox.
# Claude MCP, Read, Edit, NotebookEdit, and additionalDirectories permissions have
# no equivalent in Codex command rules and are intentionally not represented here.

# ---------------------------
# git
# ---------------------------

prefix_rule(
    pattern = [
        "git",
        [
            "add",
            "apply",
            "branch",
            "checkout",
            "cherry-pick",
            "commit",
            "fetch",
            "mv",
            "rm",
            "stash",
            "switch",
            "worktree",
        ],
    ],
    decision = "allow",
    justification = "Allow repository-local Git mutations outside the sandbox.",
)

prefix_rule(
    pattern = [
        "git",
        [
            "merge",
            "pull",
            "push",
            "rebase",
            "reset",
            "restore",
            "tag",
            "publish",
        ],
    ],
    decision = "prompt",
    justification = "Git operations that mutate history, remotes, or the working tree require approval.",
    match = [
        "git merge main",
        "git pull",
        "git push origin HEAD",
        "git rebase main",
        "git reset --hard HEAD",
        "git restore .",
        "git tag v1.0.0",
        "git publish",
    ],
)

# ---------------------------
# gh
# ---------------------------

prefix_rule(
    pattern = [
        "gh",
        "pr",
        [
            "view",
            "list",
            "diff"
        ]
    ],
    decision = "allow",
    justification = "Allow read-only GitHub pull request commands outside the sandbox.",
)

prefix_rule(
    pattern = ["gh", "issue", "view"],
    decision = "allow",
    justification = "Allow read-only GitHub issue commands outside the sandbox.",
)

prefix_rule(
    pattern = ["gh", "release", "list"],
    decision = "allow",
    justification = "Allow read-only GitHub release commands outside the sandbox.",
)

prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "prompt",
    justification = "Creating a pull request publishes repository state and should be approved explicitly.",
    match = [
        "gh pr create --draft --title test --body body",
    ],
    not_match = [
        "gh pr view 123",
    ],
)

# ---------------------------
# allow
# ---------------------------

prefix_rule(
    pattern = [
        [
            "cat",
            "cp",
            "find",
            "grep",
            "jq",
            "ls",
            "rg",
            "touch",
        ],
    ],
    decision = "allow",
    justification = "Allow the shell commands permitted by Claude settings.",
)

prefix_rule(
    pattern = ["mise", "x", "--"],
    decision = "allow",
)

# ---------------------------
# prompt
# ---------------------------

prefix_rule(
    pattern = [
        [
            "curl",
            "wget",
            "rm",
        ],
    ],
    decision = "prompt",
    justification = "Network fetches and file deletion should be approved explicitly.",
    match = [
        "curl https://example.com",
        "wget https://example.com/file",
        "rm file.txt",
        "rm -r build",
    ],
)

# ---------------------------
# forbidden
# ---------------------------

prefix_rule(
    pattern = ["env"],
    decision = "forbidden",
    justification = "Do not dump or run commands through the full inherited environment.",
    match = [
        "env",
        "env FOO=bar printenv",
    ],
)

prefix_rule(
    pattern = [
        [
            "mongod",
            "mysql",
            "nc",
            "op",
            "psql",
            "sudo",
        ],
    ],
    decision = "forbidden",
    justification = "Database access, raw network connections, password-manager access, and privileged commands are not allowed.",
    match = [
        "mongod --config mongo.conf",
        "mysql -h localhost",
        "nc -vz example.com 443",
        "op item get example",
        "psql postgres://localhost/db",
        "sudo ls /var/root",
    ],
)

prefix_rule(
    pattern = ["npm", ["remove", "uninstall"]],
    decision = "forbidden",
    justification = "Package removal should be requested explicitly by the user.",
    match = [
        "npm remove left-pad",
        "npm uninstall left-pad",
    ],
    not_match = [
        "npm install",
    ],
)

# ---------------------------
# rm restrictions
# ---------------------------

prefix_rule(
    pattern = [
        "rm",
        [
            "-rf",
            "-fr",
            "-r",
            "-f",
            "--recursive",
            "--force",
        ],
    ],
    decision = "forbidden",
    justification = "Recursive or forced deletion options are not allowed.",
    match = [
        "rm -rf build",
        "rm -fr build",
        "rm -r -f build",
        "rm -f -r build",
        "rm --recursive --force build",
        "rm --force --recursive build",
    ],
)
